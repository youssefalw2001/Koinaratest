# Koinara API production variables
NODE_ENV=production
PORT=3003
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB

# Required in production
ADMIN_SECRET=replace_with_long_random_secret
CORS_ALLOWED_ORIGINS=https://youssefalw2001.github.io,https://youssefalw2001.github.io/Koinaratest

# Telegram auth
TELEGRAM_BOT_TOKEN=replace_with_botfather_token

# TON payments / verification wallet
KOINARA_TON_WALLET=replace_with_production_ton_wallet

# Optional but recommended
REDIS_URL=
VITE_API_URL=https://your-api-url.up.railway.app
